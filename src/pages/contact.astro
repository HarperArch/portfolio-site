---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config/site";

const emailDisplay = site.social.email.replace(/^mailto:/i, "");
---

<BaseLayout
  title="Contact"
  description="How to reach me — email and professional profiles."
>
  <header class="stack page-head">
    <h1 class="h1">Contact</h1>
  </header>

  <ul class="contact-list surface">
    <li class="contact-item">
      <div class="contact-meta">
        <span class="label">Email</span>
        <span class="address">{emailDisplay}</span>
      </div>
      <a class="btn btn-primary" href={site.social.email}>Send email</a>
    </li>
    <li class="contact-item">
      <div class="contact-meta">
        <span class="label">GitHub</span>
        <span class="address">{site.social.github}</span>
      </div>
      <a
        class="btn btn-primary"
        href={site.social.github}
        target="_blank"
        rel="noopener noreferrer">Open GitHub</a
      >
    </li>
    <li class="contact-item">
      <div class="contact-meta">
        <span class="label">LinkedIn</span>
        <span class="address">{site.social.linkedin}</span>
      </div>
      <a
        class="btn btn-primary"
        href={site.social.linkedin}
        target="_blank"
        rel="noopener noreferrer">Open LinkedIn</a
      >
    </li>
  </ul>
</BaseLayout>

<style>
  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0.35rem 0;
    width: 100%;
    max-width: none;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.25rem clamp(1.25rem, 4vw, 2.25rem);
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
  }

  .contact-item:last-child {
    border-bottom: none;
  }

  @media (min-width: 560px) {
    .contact-item {
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .contact-item .btn {
      flex-shrink: 0;
    }
  }

  .contact-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
    flex: 1 1 auto;
  }

  .label {
    font-weight: 600;
    color: var(--muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .address {
    font-size: 0.98rem;
    color: var(--text);
    word-break: break-word;
    overflow-wrap: anywhere;
    line-height: 1.5;
  }
</style>
