---
import type { CollectionEntry } from "astro:content";
import { href, resolveLink } from "../utils/paths";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, shortDescription, date, tags, links } = project.data;
const d = date instanceof Date ? date : new Date(date);
---

<article class="card surface card--interactive">
  <h2 class="card-title">
    <a href={href(`/projects/${project.id}`)}>{title}</a>
  </h2>
  <p class="muted card-desc">{shortDescription}</p>
  <p class="meta muted">
    <time datetime={d.toISOString().slice(0, 10)}>
      {d.toLocaleDateString(undefined, {
        year: "numeric",
        month: "short",
      })}
    </time>
  </p>
  {
    tags.length > 0 && (
      <div class="tag-row card-tags">
        {tags.map((t) => (
          <span class="pill">{t}</span>
        ))}
      </div>
    )
  }
  <div class="links">
    {
      links.github && (
        <a href={links.github} target="_blank" rel="noopener noreferrer">
          GitHub
        </a>
      )
    }
    {
      links.demo && (
        <a href={links.demo} target="_blank" rel="noopener noreferrer">
          Demo
        </a>
      )
    }
    {
      links.report && (
        <a
          href={resolveLink(links.report)}
          target="_blank"
          rel="noopener noreferrer"
          class="report"
        >
          Report
        </a>
      )
    }
    {
      links.notebook && (
        <a
          href={resolveLink(String(links.notebook))}
          {...(String(links.notebook).startsWith("http")
            ? { target: "_blank", rel: "noopener noreferrer" }
            : { download: true })}
        >
          Notebook
        </a>
      )
    }
    {
      links.recommendation && (
        <a
          href={resolveLink(links.recommendation)}
          target="_blank"
          rel="noopener noreferrer"
        >
          Letter
        </a>
      )
    }
    <a href={href(`/projects/${project.id}`)} class="more">Details →</a>
  </div>
</article>

<style>
  .card {
    padding: 1.35rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    height: 100%;
  }

  .card--interactive {
    cursor: default;
  }

  .card--interactive:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lift);
    border-color: color-mix(in oklab, var(--accent) 20%, var(--border));
    transition: transform var(--t-med) var(--ease), box-shadow var(--t-med) var(--ease),
      border-color var(--t-med) var(--ease);
  }

  .card-title {
    font-family: var(--font-sans);
    font-size: 1.08rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.3;
  }
  .card-title a {
    color: var(--text);
    text-decoration: none;
    transition: color var(--t-med) var(--ease);
  }
  .card-title a:hover {
    color: var(--accent-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .card-desc {
    margin: 0;
    flex: 1;
  }
  .meta {
    margin: 0;
    font-size: 0.85rem;
  }
  .card-tags {
    margin-top: 0.25rem;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    margin-top: 0.5rem;
    font-size: 0.88rem;
    font-weight: 500;
  }

  .links a {
    color: var(--accent-secondary);
    text-decoration: none;
    transition: color var(--t-med) var(--ease);
  }

  .links a:hover {
    color: var(--accent-hover);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .more {
    margin-left: auto;
    color: var(--muted);
  }
  .more:hover {
    color: var(--accent-secondary);
  }
</style>
