---
import { site as siteInfo } from "../config/site";
import { href as siteHref } from "../utils/paths";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

function activeFor(route: string) {
  const full = siteHref(route).replace(/\/$/, "") || "/";
  if (route === "/") return pathname === full;
  return pathname === full || pathname.startsWith(`${full}/`);
}

const links = [
  { path: "/", label: "Home" },
  { path: "/projects", label: "Projects" },
  { path: "/resume", label: "Resume" },
  { path: "/contact", label: "Contact" },
] as const;
---

<header class="header surface">
  <div class="wrap header-inner">
    <a class="brand" href={siteHref("/")}>{siteInfo.title}</a>
    <nav class="nav" aria-label="Primary">
      <ul>
        {
          links.map(({ path, label }) => (
            <li>
              <a
                href={siteHref(path)}
                class:list={["nav-link", { active: activeFor(path) }]}
                aria-current={activeFor(path) ? "page" : undefined}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <button
      type="button"
      class="btn theme-toggle"
      id="theme-toggle"
      aria-label="Toggle dark mode"
    >
      <span class="theme-icon" aria-hidden="true">◐</span>
    </button>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    margin: 0.75rem auto 0;
    width: min(100% - 2rem, var(--max));
    border-radius: var(--radius-lg);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.85rem 1.15rem;
    flex-wrap: wrap;
  }
  .brand {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    text-decoration: none;
    color: var(--text);
    margin-right: auto;
    transition: color var(--t-med) var(--ease);
  }
  .brand:hover {
    color: var(--accent-secondary);
  }
  .nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    text-decoration: none;
    color: var(--muted);
    font-weight: 500;
    padding: 0.2rem 0;
    transition: color var(--t-med) var(--ease), box-shadow var(--t-med) var(--ease);
  }
  .nav-link:hover {
    color: var(--text);
  }
  .nav-link.active {
    color: var(--text);
    font-weight: 600;
    box-shadow: inset 0 -2px 0 0 var(--accent-warm);
  }
  .theme-toggle {
    padding: 0.35rem 0.6rem;
    min-width: 2.5rem;
    flex-shrink: 0;
  }
  .theme-icon {
    font-size: 1.1rem;
    line-height: 1;
  }
</style>

<script is:inline>
  (function () {
    const root = document.documentElement;
    const key = "portfolio-theme";
    const mq = window.matchMedia("(prefers-color-scheme: dark)");
    function apply(theme) {
      if (theme === "light") root.setAttribute("data-theme", "light");
      else if (theme === "dark") root.setAttribute("data-theme", "dark");
      else root.removeAttribute("data-theme");
    }
    const stored = localStorage.getItem(key);
    if (stored === "light" || stored === "dark") apply(stored);
    else apply("system");
    const btn = document.getElementById("theme-toggle");
    btn?.addEventListener("click", () => {
      const cur =
        root.getAttribute("data-theme") ||
        (mq.matches ? "dark" : "light");
      const next =
        cur === "dark" ? "light" : cur === "light" ? "system" : "dark";
      if (next === "system") {
        localStorage.removeItem(key);
        root.removeAttribute("data-theme");
      } else {
        localStorage.setItem(key, next);
        apply(next);
      }
    });
  })();
</script>
